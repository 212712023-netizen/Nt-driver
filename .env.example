NODE_ENV=production
PORT=3000
SESSION_SECRET=troque-por-uma-chave-grande-e-aleatoria
APP_BASE_URL=https://seu-app.exemplo.com
SESSION_TABLE_NAME=user_sessions
PUBLIC_REGISTER_ENABLED=false

# Banco local no mesmo app (Fly volume ou arquivo local)
# Use DB_CLIENT=sqlite para rodar tudo no mesmo app
DB_CLIENT=sqlite
SQLITE_FILE=/data/ntdriver.db

# Supabase PostgreSQL (use Session Pooler para IPv4)
# Formato:
# postgresql://postgres:SUA_SENHA@HOST_POOLER:6543/postgres?sslmode=require
DATABASE_URL=

# SMTP opcional para reset de senha e verificação de email
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
EMAIL_VERIFICATION_TOKEN_MINUTES=1440
